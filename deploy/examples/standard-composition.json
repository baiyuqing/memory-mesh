{
  "composition": {
    "blocks": [
      {
        "kind": "storage.local-pv",
        "name": "storage",
        "parameters": { "size": "5Gi" }
      },
      {
        "kind": "datastore.postgresql",
        "name": "db",
        "parameters": { "version": "16", "replicas": "3" },
        "inputs": { "storage": "storage/pvc-spec" }
      },
      {
        "kind": "security.password-rotation",
        "name": "rotator",
        "inputs": { "upstream-dsn": "db/dsn" }
      },
      {
        "kind": "gateway.pgbouncer",
        "name": "pooler",
        "inputs": {
          "upstream-dsn": "db/dsn",
          "upstream-credential": "rotator/credential"
        }
      }
    ]
  }
}
